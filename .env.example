# Supabase (client-safe — prefixed with EXPO_PUBLIC_)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — server-side only (Railway cron). Never put in mobile bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API — server-side only (Railway cron + Supabase Edge Functions). Never put in mobile bundle.
ANTHROPIC_API_KEY=

# Railway cron security secret — generated randomly, shared between Railway and Supabase Edge Function
RAILWAY_CRON_SECRET=
